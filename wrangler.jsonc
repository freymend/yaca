{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yaca",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "dist"
  },
  "cache": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}