{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yaca",
  "compatibility_date": "2026-07-16",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "directory": "dist",
  },
  "main": "src/worker.ts",
  "cache": {
    "enabled": true,
  },
  "preview_urls": false,
  "workers_dev": false,
  "compatibility_flags": ["nodejs_compat"],
}
